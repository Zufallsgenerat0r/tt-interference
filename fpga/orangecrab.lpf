# OrangeCrab r0.2 (ECP5-85F) pin constraints
# Adjust PMOD pin assignments to match your physical wiring.

# 48 MHz oscillator
LOCATE COMP "clk48" SITE "A9";
IOBUF PORT "clk48" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk48" 48.0 MHZ;
FREQUENCY NET "clk_25m" 25.2 MHZ;

# User button
LOCATE COMP "usr_btn" SITE "J17";
IOBUF PORT "usr_btn" IO_TYPE=SSTL135_I;

# RGB LED (active low)
LOCATE COMP "led_r" SITE "K4";
LOCATE COMP "led_g" SITE "M3";
LOCATE COMP "led_b" SITE "J3";
IOBUF PORT "led_r" IO_TYPE=LVCMOS33;
IOBUF PORT "led_g" IO_TYPE=LVCMOS33;
IOBUF PORT "led_b" IO_TYPE=LVCMOS33;

# VGA PMOD on GPIO header
# uo_out mapping: {HSYNC, B0, G0, R0, VSYNC, B1, G1, R1}
# Wire your VGA PMOD to these GPIO pins:
#   pmod[0] = R1    -> GPIO 0
#   pmod[1] = G1    -> GPIO 1
#   pmod[2] = B1    -> GPIO 5
#   pmod[3] = VSYNC -> GPIO 6
#   pmod[4] = R0    -> GPIO 9
#   pmod[5] = G0    -> GPIO 10
#   pmod[6] = B0    -> GPIO 11
#   pmod[7] = HSYNC -> GPIO 12
LOCATE COMP "pmod[0]" SITE "N17";
LOCATE COMP "pmod[1]" SITE "M18";
LOCATE COMP "pmod[2]" SITE "B10";
LOCATE COMP "pmod[3]" SITE "B9";
LOCATE COMP "pmod[4]" SITE "C8";
LOCATE COMP "pmod[5]" SITE "B8";
LOCATE COMP "pmod[6]" SITE "A8";
LOCATE COMP "pmod[7]" SITE "H2";
IOBUF PORT "pmod[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[1]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[2]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[3]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[4]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[5]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[6]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[7]" IO_TYPE=LVCMOS33;
